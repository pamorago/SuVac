@model SuVac.Application.DTOs.RolDTO
@{
    ViewData["Title"] = "Detalles";
}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 data-i18n="rol.detallesTitle">Detalles</h1>
            <div class="card">
                <div class="card-body">
                    <p><strong>ID:</strong> @Model.RolId</p>
                    <p><strong data-i18n="comun.nombre">Nombre</strong>: @Model.Nombre</p>
                </div>
            </div>
            <a asp-action="Edit" asp-route-id="@Model.RolId" class="btn btn-warning mt-3"
               data-i18n="comun.editar">Editar</a>
            <a asp-action="Index" class="btn btn-secondary mt-3" data-i18n="comun.volver">Volver</a>
        </div>
    </div>
</div>