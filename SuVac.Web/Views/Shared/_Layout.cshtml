<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SuVac</title>
    <link rel="icon" type="image/png" href="~/img/Icono%20Subasta.png" asp-append-version="true" />
    <script type="importmap"></script>
    <!--Preconecci�n (mejorar carga CDN)-->
    <link rel="preconnect" href="https://cdnjs.cloudfare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <!--Bootswatch Brite-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5/dist/brite/bootstrap.min.css" />
    <!--Boostrap Icons-->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <!--SweetAlert 2-->
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/1.1.2/css/bootstrap-multiselect.css"
          crossorigin="anonymous" referrerpolicy="no-referrer" />


    <!--Estilos propios-->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SuVac.Web.styles.css" asp-append-version="true" />

    <!-- I18N: ocultar body antes de renderizar para evitar flash de texto en español -->
    <!-- Se ejecuta síncronamente: si el idioma guardado no es 'es', oculta hasta que
         i18n.js termine de aplicar las traducciones y llame a showBody() -->
    <script>
        (function () {
            try {
                var lang = localStorage.getItem('suvac_lang');
                if (lang && lang !== 'es') {
                    document.documentElement.style.visibility = 'hidden';
                }
            } catch (e) { }
        })();
    </script>

    <!-- [DEMO] Usuario simulado por pestaña: sincroniza sessionStorage → cookie en cada carga
         La cookie es leída por UsuarioSimuladoMiddleware al inicio de cada request.
         Los fetch() también llevan la cabecera X-Suvac-Uid para peticiones AJAX. -->
    <script>
        (function () {
            var KEY = 'suvac_uid';
            var COOKIE = 'suvac-uid';
            function uid() { return parseInt(sessionStorage.getItem(KEY) || '2') || 2; }
            function syncCookie() {
                document.cookie = COOKIE + '=' + uid() + '; path=/; SameSite=Strict';
            }
            // Sincronizar en cada carga de página (cubre navegación y form POSTs)
            syncCookie();
            // Inyectar cabecera en todos los fetch() (cubre AJAX/SignalR negotiate)
            var _fetch = window.fetch;
            window.fetch = function (input, init) {
                init = init || {};
                init.headers = Object.assign({ 'X-Suvac-Uid': String(uid()) }, init.headers);
                return _fetch.call(this, input, init);
            };
            // Sincronizar antes de cualquier clic en enlace (navegación GET)
            document.addEventListener('click', function (e) {
                var a = e.target && e.target.closest('a[href]');
                if (a) syncCookie();
            }, true);
            // Sincronizar antes de cualquier envío de formulario (form POST)
            document.addEventListener('submit', syncCookie, true);
        })();
    </script>

</head>
<body class="d-flex flex-column min-vh-100 bg-body">
    <!-- Accesibilidad: salto a contenido -->
    <a class="visually-hidden-focusable position-absolute top-0 start-0 p-2 bg-body border rounded"
       href="#mainContent">
        Saltar al contenido
    </a>

    <header class="sticky-top">
        @await Html.PartialAsync("_Menu")
    </header>

    <main id="mainContent" class="flex-grow-1">
        <div class="container py-3">
            @RenderBody()
        </div>
    </main>

    <footer class="mt-auto border-top">
        <div class="container py-3 small text-muted d-flex flex-column flex-md-row gap-2 justify-content-between align-items-md-center">
            <div>
                &copy; @DateTime.Now.Year - SuVac
            </div>
            <div>
                Paula Nicole Mora Gómez &amp; Angélica Jazmín Esquivel Mairena
            </div>
            <div>
                <a class="link-secondary text-decoration-none" asp-area="" asp-controller="Home" asp-action="Privacy"
                   data-i18n="footer.privacidad">Privacidad</a>
            </div>
        </div>
    </footer>

    <!-- I18N EARLY: traduce el DOM antes de cargar jQuery/Bootstrap/SweetAlert.
         Al estar después de </footer>, todo el contenido de la página ya está en el DOM.
         Usa únicamente localStorage (sin red), por lo que es instantáneo. -->
    <script>
        (function () {
            var CACHE_VER = '2'; // ← mantener sincronizado con CACHE_VERSION en i18n.js
            try {
                var lang = localStorage.getItem('suvac_lang');

                if (!lang || lang === 'es') {
                    document.documentElement.style.visibility = '';
                    return;
                }

                var ver = localStorage.getItem('suvac_i18n_v');
                var raw = localStorage.getItem('suvac_i18n_' + lang);

                if (ver !== CACHE_VER || !raw) {
                    return; // i18n.js hará el fetch y llamará showBody()
                }

                var t = JSON.parse(raw);

                function resolve(obj, key) {
                    return key.split('.').reduce(function (o, k) {
                        return (o && o[k] !== undefined ? o[k] : null);
                    }, obj);
                }

                document.querySelectorAll('[data-i18n]').forEach(function (el) {
                    el.getAttribute('data-i18n').split(';').forEach(function (part) {
                        part = part.trim();
                        if (!part) return;
                        var m = part.match(/^\[([^\]]+)\](.+)$/);
                        if (m) {
                            var v = resolve(t, m[2]);
                            if (v !== null) el.setAttribute(m[1], v);
                        } else {
                            var v = resolve(t, part);
                            if (v === null) return;
                            if (el.children.length === 0) {
                                el.textContent = v;
                            } else {
                                var sp = el.querySelector(':scope > .i18n-text');
                                if (!sp) {
                                    sp = document.createElement('span');
                                    sp.className = 'i18n-text';
                                    Array.from(el.childNodes)
                                        .filter(function (n) { return n.nodeType === 3; })
                                        .forEach(function (n) { n.textContent = ''; });
                                    el.appendChild(sp);
                                }
                                sp.textContent = v;
                            }
                        }
                    });
                });

                // Actualizar botón de idioma
                var btn = document.getElementById('btn-lang-switch');
                if (btn) {
                    btn.setAttribute('data-lang-target', lang === 'en' ? 'es' : 'en');
                    var ts = btn.querySelector('.lang-btn-text');
                    var lbl = resolve(t, 'lang.switchBtn');
                    if (ts && lbl) ts.textContent = lbl;
                    var badge = document.getElementById('lang-current-badge');
                    var cur = resolve(t, 'lang.currentLang');
                    if (badge && cur) badge.textContent = cur;
                }

                document.documentElement.style.visibility = '';
            } catch (e) {
                document.documentElement.style.visibility = '';
            }
        })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"
            crossorigin="anonymous"></script>

            
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
    <!-- Multi-select -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-multiselect/1.1.2/js/bootstrap-multiselect.min.js"
            crossorigin="anonymous" referrerpolicy="no-referrer"></script >

            <!--SweetAlert 2-->
    <script src="~/lib/sweetalert2/dist/sweetalert2.all.min.js"></script>
    <!-- SWEETALERT NOTIFICATION -->
    @if (TempData["Notificacion"] != null || ViewBag.Notificacion != null)
    {
        var notificacion = TempData["Notificacion"] ?? ViewBag.Notificacion;
        <script type="text/javascript">

            const payload = @Html.Raw(notificacion);

            if (payload) {
                Swal.fire(payload);
            }
        </script>
    }

    <script src="~/js/site.js" asp-append-version="true"></script>
    <!-- I18N: language switching, event handling, fetch on cache miss -->
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


