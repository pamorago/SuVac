@using System.Security.Claims
@{
    var isAuth = User.Identity?.IsAuthenticated == true;
    var nombre = User.FindFirstValue(ClaimTypes.Name) ?? "Invitado";
    var rol = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var esAdmin = rol == "Admin";
}

<nav class="navbar navbar-expand-lg bg-primary" data-bs-theme="light">
    <div class="container">
        <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
            <i class="bi bi-cow me-2"></i>SuVac
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain"
                aria-controls="navbarMain" aria-expanded="false" aria-label="Abrir menu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                @if (isAuth)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Ganado" asp-action="Index">Ganado</a>
                    </li>
                }

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                       aria-expanded="false">Subastas</a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" asp-controller="Subasta" asp-action="Activas">Activas</a></li>
                        <li><a class="dropdown-item" asp-controller="Subasta" asp-action="Finalizadas">Finalizadas</a>
                        </li>
                        @if (esAdmin)
                        {
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li><a class="dropdown-item" asp-controller="Subasta" asp-action="Index">
                                <i class="bi bi-gear me-1"></i>Mantenimiento</a></li>
                            }
                        </ul>
                    </li>

                    @if (isAuth)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Pago" asp-action="Index">Pagos</a>
                        </li>
                    }

                    @if (esAdmin)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                                   aria-expanded="false">
                                <i class="bi bi-shield-fill-check me-1"></i>Administracion
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Usuario" asp-action="Index">
                                    <i class="bi bi-people me-1"></i>Usuarios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Categoria" asp-action="Index">
                                        <i class="bi bi-tags me-1"></i>Categorias</a></li>
                                        <li><a class="dropdown-item" asp-controller="Raza" asp-action="Index">
                                            <i class="bi bi-diagram-2 me-1"></i>Razas</a></li>
                                            <li><a class="dropdown-item" asp-controller="TipoGanado" asp-action="Index">
                                                <i class="bi bi-list-ul me-1"></i>Tipos de Ganado</a></li>
                                                <li><a class="dropdown-item" asp-controller="Rol" asp-action="Index">
                                                    <i class="bi bi-person-badge me-1"></i>Roles</a></li>
                                                </ul>
                                            </li>
                                        }
                                    </ul>

                                    <ul class="navbar-nav ms-auto align-items-center gap-2">

                                        <li class="nav-item">
                                            <button id="btn-lang-switch" type="button"
                                                    class="btn btn-sm btn-outline-light d-flex align-items-center gap-1" data-lang-target="en"
                                                    title="Cambiar idioma / Switch language">
                                                <i class="bi bi-translate"></i>
                                                <span id="lang-current-badge" class="fw-semibold" style="min-width:1.6rem;">ES</span>
                                                <span class="vr opacity-50"></span>
                                                <span class="lang-btn-text" data-i18n="lang.switchBtn">English</span>
                                            </button>
                                        </li>

                                        <li class="nav-item dropdown">
                                            <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" role="button"
                                                   data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-person-circle me-1 fs-5"></i>
                                                <span class="d-none d-sm-inline">@nombre</span>
                                                @if (isAuth)
                                                {
                                                    <span class="badge text-bg-warning ms-2 small">@rol</span>
                                                }
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                @if (isAuth)
                                                {
                                                    <li>
                                                        <span class="dropdown-item-text text-muted small">
                                                            <i class="bi bi-person me-1"></i>@nombre
                                                        </span>
                                                    </li>
                                                    <li>
                                                        <hr class="dropdown-divider">
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" asp-controller="Login" asp-action="MiPerfil">
                                                            <i class="bi bi-person-lines-fill me-1"></i>Mi perfil
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" asp-controller="Login" asp-action="Historial">
                                                            <i class="bi bi-clock-history me-1"></i>Mi historial
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item text-danger" asp-controller="Login" asp-action="LogOff">
                                                            <i class="bi bi-box-arrow-left me-1"></i>Cerrar sesion
                                                        </a>
                                                    </li>
                                                }
                                                else
                                                {
                                                    <li>
                                                        <a class="dropdown-item" asp-controller="Login" asp-action="Index">
                                                            <i class="bi bi-box-arrow-in-right me-1"></i>Iniciar sesion
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" asp-controller="Login" asp-action="Registro">
                                                            <i class="bi bi-person-plus me-1"></i>Registrarse
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </nav>
