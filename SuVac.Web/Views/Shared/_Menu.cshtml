<script>
(function () {
    function escHtml(str) {
        const d = document.createElement('div');
        d.appendChild(document.createTextNode(str ?? ''));
        return d.innerHTML;
    }

    let usuariosCargados = false;

    const dropdownEl = document.getElementById('btn-cambiar-usuario')?.closest('.dropdown');
    if (!dropdownEl) return;

    // Cargar lista al abrir el dropdown (solo la primera vez)
    dropdownEl.addEventListener('show.bs.dropdown', async () => {
        if (usuariosCargados) return;
        try {
            const resp = await fetch('/Usuario/ListaSimulada');
            const usuarios = await resp.json();

            const loading = document.getElementById('usuarios-loading');
            if (loading) loading.remove();

            const ul = document.getElementById('dropdown-usuarios-sim');

            usuarios.forEach(u => {
                const li = document.createElement('li');
                li.innerHTML =
                    `<a class="dropdown-item d-flex align-items-center gap-2${u.activo ? ' active fw-semibold' : ''}"
                        href="#" data-userid="${u.usuarioId}">
                        <i class="bi bi-person-circle"></i>
                        <span class="flex-grow-1">${escHtml(u.nombreCompleto)}</span>
                        <span class="badge text-bg-secondary small">${escHtml(u.nombreRol ?? '')}</span>
                        ${u.activo ? '<i class="bi bi-check-circle-fill text-success ms-1"></i>' : ''}
                     </a>`;
                li.querySelector('a').addEventListener('click', async (e) => {
                    e.preventDefault();
                    await cambiarUsuario(u.usuarioId, u.nombreCompleto);
                });
                ul.appendChild(li);
            });

            // Set initial label
            const actual = usuarios.find(u => u.activo);
            if (actual)
                document.getElementById('label-usuario-sim').textContent = actual.nombreCompleto;

            usuariosCargados = true;
        } catch (err) {
            console.error('[Demo] Error cargando usuarios:', err);
        }
    });

    // Set label on page load via a separate quick fetch
    fetch('/Usuario/ListaSimulada')
        .then(r => r.json())
        .then(usuarios => {
            const actual = usuarios.find(u => u.activo);
            if (actual) document.getElementById('label-usuario-sim').textContent = actual.nombreCompleto;
        })
        .catch(() => {});

    async function cambiarUsuario(userId, nombre) {
        // Abre una nueva pestaña como el usuario seleccionado en la misma página.
        // La pestaña actual NO cambia de usuario — cada pestaña mantiene su propio usuario
        // gracias a sessionStorage (aislado por pestaña en el navegador).
        const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
        window.open('/Usuario/IniciarComoUsuario?userId=' + userId + '&returnUrl=' + returnUrl, '_blank');
    }
})();
</script>

