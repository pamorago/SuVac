@model IEnumerable<SuVac.Application.DTOs.PagoDTO>

@{
    ViewData["Title"] = "Gestión de Pagos";
    var total = Model?.Count() ?? 0;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1" data-i18n="pago.historialTitle">Gestión de Pagos</h1>
        <p class="text-muted mb-0"><span data-i18n="pago.totalPagos">Total de pagos:</span> <strong>@total</strong>.</p>
    </div>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        <div data-i18n="pago.noHay">No hay pagos registrados en este momento.</div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th data-i18n="pago.colSubasta">Subasta</th>
                    <th data-i18n="pago.colUsuario">Usuario</th>
                    <th data-i18n="pago.colMonto">Monto</th>
                    <th data-i18n="pago.colEstado">Estado</th>
                    <th data-i18n="pago.colFecha">Fecha Pago</th>
                    <th data-i18n="pago.colAcciones">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PagoId</td>
                        <td>@item.SubastaId</td>
                        <td>@item.UsuarioId</td>
                        <td>$@item.Monto.ToString("F2")</td>
                        <td>
                            @if (item.EstadoPagoId == 1)
                            {
                                <span class="badge bg-warning" data-i18n="pago.estadoPendiente">Pendiente</span>
                            }
                            else
                            {
                                <span class="badge bg-success" data-i18n="pago.estadoConfirmado">Confirmado</span>
                            }
                        </td>
                        <td>@(item.FechaPago?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                        <td>
                            <a asp-controller="Pago" asp-action="Details" asp-route-id="@item.PagoId"
                               class="btn btn-sm btn-info" data-i18n="subasta.verDetalle">Ver</a>
                            <a asp-controller="Pago" asp-action="Edit" asp-route-id="@item.PagoId"
                               class="btn btn-sm btn-warning" data-i18n="comun.editar">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}