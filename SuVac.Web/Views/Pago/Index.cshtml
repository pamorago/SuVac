@model IEnumerable<SuVac.Application.DTOs.PagoDTO>

@{
    ViewData["Title"] = "Pagos";
    var total      = Model?.Count() ?? 0;
    var pendientes = Model?.Count(p => p.NombreEstadoPago == "Pendiente") ?? 0;
    var confirmados= Model?.Count(p => p.NombreEstadoPago == "Confirmado") ?? 0;
}

@if (TempData["Notificacion_Mensaje"] is string msg)
{
    var tipo = TempData["Notificacion_Tipo"]?.ToString() ?? "info";
    <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
        @msg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Encabezado -->
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-credit-card-2-front me-2 text-success"></i>Gestión de Pagos</h1>
        <p class="text-muted mb-0">Total: <strong>@total</strong> &mdash;
            <span class="text-warning fw-semibold">@pendientes pendientes</span> /
            <span class="text-success fw-semibold">@confirmados confirmados</span>
        </p>
    </div>
</div>

@if (!Model?.Any() ?? true)
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        No hay pagos registrados. Se generan automáticamente al cerrar una subasta con ganador.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Subasta / Ganado</th>
                    <th>Comprador</th>
                    <th>Monto</th>
                    <th>Estado</th>
                    <th>Fecha</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model!)
                {
                    <tr>
                        <td class="fw-semibold text-muted small">@p.PagoId</td>
                        <td>
                            <div class="fw-semibold">@(p.NombreGanado ?? "—")</div>
                            <div class="text-muted small">Subasta #@p.SubastaId</div>
                        </td>
                        <td>
                            <i class="bi bi-person-circle me-1 text-muted"></i>@(p.NombreUsuario ?? "—")
                        </td>
                        <td class="fw-semibold text-success">₡@p.Monto.ToString("N2")</td>
                        <td>
                            @if (p.NombreEstadoPago == "Pendiente")
                            {
                                <span class="badge text-bg-warning">
                                    <i class="bi bi-hourglass-split me-1"></i>Pendiente
                                </span>
                            }
                            else
                            {
                                <span class="badge text-bg-success">
                                    <i class="bi bi-check-circle-fill me-1"></i>Confirmado
                                </span>
                            }
                        </td>
                        <td class="text-muted small">@(p.FechaPago?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@p.PagoId"
                               class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-eye me-1"></i>Ver
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
