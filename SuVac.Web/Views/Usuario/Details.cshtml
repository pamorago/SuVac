@model SuVac.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = $"Perfil de {Model.NombreCompleto}";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-10 col-xl-8 offset-md-1 offset-xl-2">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 data-i18n="usuario.detallesTitle">
                        <i class="bi bi-person"></i> Perfil de Usuario
                    </h3>
                </div>
                <div class="card-body">
                    <!-- Información Básica -->
                    <h5 class="mb-3" data-i18n="usuario.infoBasica">Información Básica del Perfil</h5>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold" data-i18n="usuario.nombreCompleto">Nombre Completo</label>
                            <p class="form-control-plaintext">@Model.NombreCompleto</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold" data-i18n="usuario.email">Email</label>
                            <p class="form-control-plaintext">@Model.Correo</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold" data-i18n="usuario.rol">Rol</label>
                            <p class="form-control-plaintext">
                                @if (Model.NombreRol == "Admin")
                                {
                                    <span class="badge bg-danger">@Model.NombreRol</span>
                                }
                                else if (Model.NombreRol == "Vendedor")
                                {
                                    <span class="badge bg-warning text-dark">@Model.NombreRol</span>
                                }
                                else
                                {
                                    <span class="badge bg-info">@Model.NombreRol</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold" data-i18n="usuario.estado">Estado</label>
                            <p class="form-control-plaintext">
                                @if (Model.NombreEstado == "Activo")
                                {
                                    <span class="badge bg-success">@Model.NombreEstado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Model.NombreEstado</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold" data-i18n="usuario.fechaRegistro">Fecha de
                                Registro</label>
                                <p class="form-control-plaintext">@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm:ss")</p>
                            </div>
                        </div>

                        <hr />

                        <!-- Historial Mínimo -->
                        <h5 class="mb-3" data-i18n="usuario.historial">Actividad del Usuario</h5>
                        <p class="text-muted mb-3">Resumen operativo del usuario como vendedor y como participante en
                            subastas.</p>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="card bg-light h-100">
                                        <div class="card-body text-center">
                                            <h6 class="card-title" data-i18n="usuario.subastasCreadas">Subastas Creadas</h6>
                                            <h2 class="text-primary">@Model.CantidadSubastasCreadas</h2>
                                            <small class="text-muted">Historial como vendedor del sistema</small>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6 mb-3">
                                    <div class="card bg-light h-100">
                                        <div class="card-body text-center">
                                            <h6 class="card-title" data-i18n="usuario.pujasRealizadas">Pujas Realizadas</h6>
                                            <h2 class="text-info">@Model.CantidadPujasRealizadas</h2>
                                            <small class="text-muted">Historial de participación en pujas</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <hr />

                            <!-- Acciones -->
                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-controller="Usuario" asp-action="Edit" asp-route-id="@Model.UsuarioId"
                                       class="btn btn-warning">
                                    <i class="bi bi-pencil me-1"></i> Editar perfil
                                </a>
                                <a asp-controller="Usuario" asp-action="Index" class="btn btn-outline-secondary"
                                       data-i18n="usuario.volverListado">
                                    <i class="bi bi-arrow-left"></i> Volver al Listado
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .card {
                border: none;
                border-radius: 0.5rem;
            }

            .form-control-plaintext {
                font-size: 1rem;
                color: #333;
            }

            .card.bg-light {
                background-color: #f8f9fa !important;
                border: 1px solid #dee2e6;
            }
        </style>