@model SuVac.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Editar Perfil de Usuario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-person-gear me-2"></i>Editar Perfil</h1>
        <p class="text-muted mb-0">ID: <strong>#@Model.UsuarioId</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver al Listado
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UsuarioId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-info-circle me-2"></i>
                <div>Solo se puede modificar el <strong>Nombre Completo</strong> y el <strong>Correo Electrónico</strong>.
                El Rol y la Fecha de Registro no son editables.</div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="NombreCompleto" class="form-label fw-semibold">Nombre Completo</label>
                    <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre completo del usuario" />
                    <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Correo" class="form-label fw-semibold">Correo Electrónico</label>
                    <input asp-for="Correo" class="form-control" type="email" placeholder="correo@ejemplo.com" />
                    <span asp-validation-for="Correo" class="text-danger small"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold text-muted">Rol <span class="text-danger small">(no editable)</span></label>
                    <p class="form-control-plaintext ps-1">
                        @if (Model.NombreRol == "Admin")
                        {
                            <span class="badge bg-danger">@Model.NombreRol</span>
                        }
                        else if (Model.NombreRol == "Vendedor")
                        {
                            <span class="badge bg-warning text-dark">@Model.NombreRol</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">@(Model.NombreRol ?? "—")</span>
                        }
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label fw-semibold text-muted">Fecha de Registro <span class="text-danger small">(no editable)</span></label>
                    <p class="form-control-plaintext ps-1">
                        <i class="bi bi-calendar me-1 text-muted"></i>
                        @Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm:ss")
                    </p>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold text-muted">Estado actual <span class="text-danger small">(use Bloquear/Activar desde el listado)</span></label>
                <p class="form-control-plaintext ps-1">
                    @if (Model.NombreEstado == "Activo")
                    {
                        <span class="badge bg-success">@Model.NombreEstado</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@(Model.NombreEstado ?? "—")</span>
                    }
                </p>
            </div>

            <hr class="my-3" />

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">
                    <i class="bi bi-save me-1"></i> Guardar Cambios
                </button>
                <a asp-action="Details" asp-route-id="@Model.UsuarioId" class="btn btn-outline-primary">
                    <i class="bi bi-eye me-1"></i> Ver Detalles
                </a>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
