@model IEnumerable<SuVac.Application.DTOs.UsuarioDTO>

@{
    ViewData["Title"] = "Usuarios";
    var total = Model?.Count() ?? 0;
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-people me-2"></i><span data-i18n="usuario.title">Usuarios del Sistema</span></h1>
        <p class="text-muted mb-0">Total de usuarios registrados: <strong>@total</strong></p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i> Nuevo Usuario
    </a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle me-2"></i>
        <div data-i18n="usuario.noHay">No hay usuarios registrados en el sistema.</div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0 align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th data-i18n="usuario.colNombre">Nombre Completo</th>
                        <th>Correo</th>
                        <th data-i18n="usuario.colRol">Rol</th>
                        <th>Estado</th>
                        <th>Fecha Registro</th>
                        <th class="text-center" data-i18n="usuario.colAcciones">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model)
                    {
                        <tr>
                            <td class="text-muted small">@usuario.UsuarioId</td>
                            <td><strong>@usuario.NombreCompleto</strong></td>
                            <td class="text-muted small">@usuario.Correo</td>
                            <td>
                                @if (usuario.NombreRol == "Admin")
                                {
                                    <span class="badge bg-danger">@usuario.NombreRol</span>
                                }
                                else if (usuario.NombreRol == "Vendedor")
                                {
                                    <span class="badge bg-warning text-dark">@usuario.NombreRol</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@usuario.NombreRol</span>
                                }
                            </td>
                            <td>
                                @if (usuario.NombreEstado == "Activo")
                                {
                                    <span class="badge bg-success">@usuario.NombreEstado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@usuario.NombreEstado</span>
                                }
                            </td>
                            <td class="small">@usuario.FechaRegistro.ToString("dd/MM/yyyy")</td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@usuario.UsuarioId"
                                   class="btn btn-sm btn-outline-primary me-1" title="Ver detalles">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@usuario.UsuarioId"
                                   class="btn btn-sm btn-outline-warning me-1" title="Editar">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-danger btn-delete-usuario"
                                        data-id="@usuario.UsuarioId" data-nombre="@usuario.NombreCompleto"
                                        title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                                <form asp-action="DeleteConfirmed" asp-route-id="@usuario.UsuarioId"
                                      method="post" id="form-delete-@usuario.UsuarioId" class="d-none">
                                    @Html.AntiForgeryToken()
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.btn-delete-usuario').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.id;
                const nombre = this.dataset.nombre;
                Swal.fire({
                    title: '¿Eliminar usuario?',
                    html: `¿Estás seguro de que deseas eliminar a <strong>${nombre}</strong>? Esta acción no se puede deshacer.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: '<i class="bi bi-trash me-1"></i>Sí, eliminar',
                    cancelButtonText: 'Cancelar'
                }).then(result => {
                    if (result.isConfirmed) {
                        document.getElementById('form-delete-' + id).submit();
                    }
                });
            });
        });
    </script>
}