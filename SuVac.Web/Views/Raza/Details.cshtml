@model SuVac.Application.DTOs.RazaDTO

@{
    ViewData["Title"] = "Detalles de la Raza";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1 data-i18n="raza.detallesTitle">Detalles de la Raza</h1>
            <div class="card">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label"><strong>ID:</strong></label>
                        <p>@Model.RazaId</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong data-i18n="comun.nombre">Nombre</strong>:</label>
                        <p>@Model.Nombre</p>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong data-i18n="comun.descripcion">Descripción</strong>:</label>
                        <p>@Model.Descripcion</p>
                    </div>
                </div>
            </div>
            <a asp-action="Edit" asp-route-id="@Model.RazaId" class="btn btn-warning mt-3"
               data-i18n="comun.editar">Editar</a>
            <a asp-action="Index" class="btn btn-secondary mt-3" data-i18n="comun.volver">Volver</a>
        </div>
    </div>
</div>