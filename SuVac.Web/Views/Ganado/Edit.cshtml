@model SuVac.Application.DTOs.GanadoDTO

@{
    ViewData["Title"] = "Editar Ganado";
}

<div class="container mt-5">
    <h1 class="mb-4">
        <i class="bi bi-pencil-square me-2"></i>Editar Ganado
    </h1>

    <form asp-controller="Ganado" asp-action="Edit" asp-route-id="@Model.GanadoId" method="post" class="card p-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="GanadoId" />

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Error de validación</strong>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar"></button>
                <ul class="mb-0">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    }
                </ul>
            </div>
        }

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Nombre" class="form-label">Nombre</label>
                <input type="text" class="form-control" asp-for="Nombre" required />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="PesoKg" class="form-label">Peso (kg)</label>
                <input type="number" class="form-control" asp-for="PesoKg" step="0.01" required />
                <span asp-validation-for="PesoKg" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Descripcion" class="form-label">Descripción</label>
            <textarea class="form-control" asp-for="Descripcion" rows="4" required></textarea>
            <span asp-validation-for="Descripcion" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="TipoGanadoId" class="form-label">Tipo de Ganado</label>
                <select class="form-select" asp-for="TipoGanadoId" asp-items="@ViewBag.TiposGanado" required>
                    <option value="">-- Seleccionar Tipo --</option>
                </select>
                <span asp-validation-for="TipoGanadoId" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="RazaId" class="form-label">Raza</label>
                <select class="form-select" asp-for="RazaId" asp-items="@ViewBag.Razas" required>
                    <option value="">-- Seleccionar Raza --</option>
                </select>
                <span asp-validation-for="RazaId" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="SexoId" class="form-label">Sexo</label>
                <select class="form-select" asp-for="SexoId" asp-items="@ViewBag.Sexos" required>
                    <option value="">-- Seleccionar Sexo --</option>
                </select>
                <span asp-validation-for="SexoId" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="FechaNacimiento" class="form-label">Fecha de Nacimiento</label>
                <input type="date" class="form-control" asp-for="FechaNacimiento" required />
                <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="CertificadoSalud" class="form-label">Certificado de Salud</label>
                <input type="text" class="form-control" asp-for="CertificadoSalud" />
                <span asp-validation-for="CertificadoSalud" class="text-danger"></span>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="UsuarioVendedorId" class="form-label">Vendedor</label>
                <select class="form-select" asp-for="UsuarioVendedorId" asp-items="@ViewBag.Usuarios" required>
                    <option value="">-- Seleccionar Vendedor --</option>
                </select>
                <span asp-validation-for="UsuarioVendedorId" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="EstadoGanadoId" class="form-label">Estado</label>
                <select class="form-select" asp-for="EstadoGanadoId" asp-items="@ViewBag.EstadosGanado" required>
                    <option value="">-- Seleccionar Estado --</option>
                </select>
                <span asp-validation-for="EstadoGanadoId" class="text-danger"></span>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">Fecha de Registro</label>
            <input type="text" class="form-control" value="@Model.FechaRegistro.ToString("dd/MM/yyyy")" readonly />
        </div>

        <div class="d-flex gap-2 mt-2">
            <button type="submit" class="btn btn-warning">
                <i class="bi bi-floppy me-1"></i> Guardar Cambios
            </button>
            <a asp-action="Details" asp-route-id="@Model.GanadoId" class="btn btn-outline-info">
                <i class="bi bi-eye me-1"></i> Ver Detalles
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-x-circle me-1"></i> Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}