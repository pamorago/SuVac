@model SuVac.Application.DTOs.GanadoDTO
@using SuVac.Application.DTOs

@{
    ViewData["Title"] = "Registrar Nuevo Ganado";
    var categorias = ViewBag.Categorias as ICollection<CategoriaDTO> ?? new List<CategoriaDTO>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-1"><i class="bi bi-plus-circle me-2"></i>Registrar Nuevo Ganado</h1>
        <p class="text-muted mb-0">Complete todos los campos obligatorios</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver al Catálogo
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            
            <h5 class="text-secondary mb-3 border-bottom pb-2">Información General</h5>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Nombre" class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
                    <input asp-for="Nombre" class="form-control" placeholder="Ej: Toro Campeón" />
                    <span asp-validation-for="Nombre" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PesoKg" class="form-label fw-semibold">Peso (kg) <span class="text-danger">*</span></label>
                    <input asp-for="PesoKg" class="form-control" type="number" step="0.01" min="1" max="9999" placeholder="Ej: 450.00" />
                    <span asp-validation-for="PesoKg" class="text-danger small"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-semibold">Descripción <span class="text-danger">*</span> <small class="text-muted">(mínimo 20 caracteres)</small></label>
                <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describa el ganado en detalle..."></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="TipoGanadoId" class="form-label fw-semibold">Tipo de Ganado <span class="text-danger">*</span></label>
                    <select asp-for="TipoGanadoId" asp-items="@ViewBag.TiposGanado" class="form-select">
                        <option value="">-- Seleccionar Tipo --</option>
                    </select>
                    <span asp-validation-for="TipoGanadoId" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="RazaId" class="form-label fw-semibold">Raza <span class="text-danger">*</span></label>
                    <select asp-for="RazaId" asp-items="@ViewBag.Razas" class="form-select">
                        <option value="">-- Seleccionar Raza --</option>
                    </select>
                    <span asp-validation-for="RazaId" class="text-danger small"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="SexoId" class="form-label fw-semibold">Sexo <span class="text-danger">*</span></label>
                    <select asp-for="SexoId" asp-items="@ViewBag.Sexos" class="form-select">
                        <option value="">-- Seleccionar Sexo --</option>
                    </select>
                    <span asp-validation-for="SexoId" class="text-danger small"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FechaNacimiento" class="form-label fw-semibold">Fecha de Nacimiento <span class="text-danger">*</span></label>
                    <input asp-for="FechaNacimiento" class="form-control" type="date" />
                    <span asp-validation-for="FechaNacimiento" class="text-danger small"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CertificadoSalud" class="form-label fw-semibold">Condición / Certificado de Salud</label>
                    <input asp-for="CertificadoSalud" class="form-control" placeholder="Ej: Certificado por SENASA 2024" />
                    <span asp-validation-for="CertificadoSalud" class="text-danger small"></span>
                </div>
            </div>

            
            <div class="mb-3">
                <label class="form-label fw-semibold">Estado inicial</label>
                <div class="form-control-plaintext ps-1">
                    <span class="badge bg-success fs-6"><i class="bi bi-check-circle me-1"></i>Activo</span>
                    <small class="text-muted ms-2">(los nuevos objetos subastables se registran como Activo)</small>
                </div>
            </div>

            
            <div class="mb-3 p-3 bg-light rounded border">
                <label asp-for="UsuarioVendedorId" class="form-label fw-semibold">Usuario Vendedor <span class="text-danger">*</span></label>
                <select asp-for="UsuarioVendedorId" asp-items="@ViewBag.Vendedores" class="form-select">
                    <option value="">-- Seleccionar Vendedor --</option>
                </select>
                <span asp-validation-for="UsuarioVendedorId" class="text-danger small"></span>
                <div class="form-text text-muted"><i class="bi bi-info-circle me-1"></i>Se asigna el usuario vendedor responsable del objeto.</div>
            </div>

            
            <div class="mb-4">
                <label class="form-label fw-semibold">Categorías <span class="text-danger">*</span> <small class="text-muted">(seleccione al menos una)</small></label>
                <span asp-validation-for="CategoriasIds" class="text-danger small d-block mb-1"></span>
                @if (!categorias.Any())
                {
                    <div class="alert alert-warning py-2">No hay categorías disponibles. Cree categorías primero.</div>
                }
                else
                {
                    <div class="row g-2">
                        @foreach (var cat in categorias)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox"
                                           name="CategoriasIds" value="@cat.CategoriaId"
                                           id="cat_@cat.CategoriaId" />
                                    <label class="form-check-label" for="cat_@cat.CategoriaId">
                                        @cat.Nombre
                                        @if (!string.IsNullOrEmpty(cat.Descripcion))
                                        {
                                            <small class="text-muted d-block">@cat.Descripcion</small>
                                        }
                                    </label>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            
            <div class="mb-3">
                <label class="form-label fw-semibold">Imágenes <span class="text-danger">*</span> <small class="text-muted">(agregue al menos una URL)</small></label>
                <span class="text-danger small d-block mb-1" id="error-imagenes">
                    @(ViewData.ModelState["ImagenesGanado"]?.Errors.FirstOrDefault()?.ErrorMessage)
                </span>
                <div id="imagenes-container">
                    <div class="input-group mb-2">
                        <input type="text" class="form-control imagen-url-input"
                               name="ImagenesGanado[0].UrlImagen"
                               placeholder="https://ejemplo.com/imagen.jpg" />
                        <button class="btn btn-outline-danger" type="button" onclick="removeImagen(this)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <button class="btn btn-outline-secondary btn-sm mt-1" type="button" onclick="addImagen()">
                    <i class="bi bi-plus-circle me-1"></i> Agregar otra imagen
                </button>
            </div>

            <hr class="my-3" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-circle me-1"></i> Registrar Ganado
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        let imgCount = document.querySelectorAll('.imagen-url-input').length;

        function addImagen() {
            const container = document.getElementById('imagenes-container');
            const div = document.createElement('div');
            div.className = 'input-group mb-2';
            div.innerHTML = `<input type="text" class="form-control imagen-url-input"
                name="ImagenesGanado[${imgCount}].UrlImagen"
                placeholder="https://ejemplo.com/imagen.jpg" />
                <button class="btn btn-outline-danger" type="button" onclick="removeImagen(this)">
                    <i class="bi bi-trash"></i>
                </button>`;
            container.appendChild(div);
            imgCount++;
        }

        function removeImagen(btn) {
            const group = btn.closest('.input-group');
            const container = document.getElementById('imagenes-container');
            if (container.querySelectorAll('.input-group').length > 1) {
                group.remove();
            } else {
                Swal.fire({ title: 'Mínimo requerido', text: 'Debe tener al menos una imagen.', icon: 'warning' });
            }
        }
    </script>
}
