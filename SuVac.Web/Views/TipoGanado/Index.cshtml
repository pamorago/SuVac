@model ICollection<SuVac.Application.DTOs.TipoGanadoDTO>
@{
    ViewData["Title"] = "Tipos de Ganado";
}
<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6"><h1 data-i18n="tipoGanado.title">Tipos de Ganado</h1></div>
        <div class="col-md-6 text-end"><a asp-action="Create" class="btn btn-primary" data-i18n="tipoGanado.crearBtn">Crear Nuevo</a></div>
    </div>
    @if (Model != null && Model.Count > 0)
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr><th>ID</th><th data-i18n="comun.nombre">Nombre</th><th data-i18n="comun.descripcion">Descripción</th><th data-i18n="comun.acciones">Acciones</th></tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TipoGanadoId</td>
                        <td>@item.Nombre</td>
                        <td>@item.Descripcion</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.TipoGanadoId" class="btn btn-info btn-sm" data-i18n="comun.verDetalles">Detalles</a>
                            <a asp-action="Edit" asp-route-id="@item.TipoGanadoId" class="btn btn-warning btn-sm" data-i18n="comun.editar">Editar</a>
                            <a asp-action="Delete" asp-route-id="@item.TipoGanadoId" class="btn btn-danger btn-sm" data-i18n="comun.eliminar">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info" data-i18n="tipoGanado.noHay">No hay tipos de ganado registrados.</div>
    }
</div>
