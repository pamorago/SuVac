@model SuVac.Application.DTOs.SubastaDetalleDTO
@{
    ViewData["Title"] = $"Detalle de Subasta #{Model.SubastaId}";
    var badgeClase = Model.EstadoSubasta switch
    {
        "Activa"     => "text-bg-success",
        "Finalizada" => "text-bg-dark",
        "Cancelada"  => "text-bg-danger",
        "Programada" => "text-bg-primary",
        "Borrador"   => "text-bg-secondary",
        _            => "text-bg-info"
    };
    var puedeEditar = (Model.EstadoSubasta == "Borrador" || Model.EstadoSubasta == "Programada")
                      && Model.FechaInicio > DateTime.Now && Model.TotalPujas == 0;
    var puedePublicar  = Model.EstadoSubasta == "Borrador";
    var puedeCancelar  = Model.EstadoSubasta != "Cancelada" && Model.EstadoSubasta != "Finalizada"
                         && (Model.FechaInicio > DateTime.Now || Model.TotalPujas == 0);
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        @if (desdeGanado)
        {
            <li class="breadcrumb-item"><a asp-controller="Ganado" asp-action="Index">Ganado</a></li>
            <li class="breadcrumb-item"><a asp-controller="Ganado" asp-action="Details"
                                               asp-route-id="@Model.GanadoId">@Model.NombreGanado</a></li>
            }
        else if (desdePujas)
            {
                <li class="breadcrumb-item"><a asp-controller="Puja" asp-action="Index" data-i18n="nav.pujas">Pujas</a></li>
            }
            else if (Model.EstadoSubasta == "Activa" || Model.EstadoSubasta == "Programada")
            {
                <li class="breadcrumb-item"><a asp-action="Activas" data-i18n="detalle.subastas">Subastas Activas</a></li>
            }
            else
            {
                <li class="breadcrumb-item"><a asp-action="Finalizadas" data-i18n="detalle.finalizadas">Finalizadas</a></li>
            }
            <li class="breadcrumb-item active" aria-current="page">Detalle #@Model.SubastaId</li>
        </ol>
    </nav>

    @if (desdeGanado)
    {
        <div class="mb-3">
            <a asp-controller="Ganado" asp-action="Details" asp-route-id="@Model.GanadoId" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.volverGanado">Volver al Ganado</span>
            </a>
        </div>
    }
    else if (desdePujas)
    {
        <div class="mb-3">
            <a asp-controller="Puja" asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.volverPujas">Volver a Pujas</span>
            </a>
        </div>
    }
    else if (Model.EstadoSubasta == "Activa" || Model.EstadoSubasta == "Programada")
    {
        <div class="mb-3">
            <a asp-action="Activas" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.volverActivas">Volver a Subastas Activas</span>
            </a>
        </div>
    }
    else if (Model.EstadoSubasta == "Finalizada" || Model.EstadoSubasta == "Cancelada")
    {
        <div class="mb-3">
            <a asp-action="Finalizadas" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.volverFinalizadas">Volver a Subastas
                Finalizadas</span>
            </a>
        </div>
    }

    <div class="row g-4">

        <!-- ══ Columna Izquierda: Ganado ═════════════════════════════════════════ -->
        <div class="col-md-5">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-cow me-1"></i> <span data-i18n="detalle.infoGanado">Información del Ganado</span>
                </div>
                <div class="card-body">

                    <!-- Imágenes del ganado -->
                    @if (Model.ImagenesGanado.Any())
                    {
                        <div id="carrusel-ganado" class="carousel slide mb-3" data-bs-ride="carousel">
                            <div class="carousel-inner rounded">
                                @for (int i = 0; i < Model.ImagenesGanado.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@Model.ImagenesGanado[i]" class="d-block w-100"
                                             alt="Imagen @(i + 1) de @Model.NombreGanado" style="height:260px; object-fit:cover;"
                                             onerror="this.src='/img/sin-imagen.png'" />
                                    </div>
                                }
                            </div>
                            @if (Model.ImagenesGanado.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#carrusel-ganado"
                                        data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon"></span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#carrusel-ganado"
                                        data-bs-slide="next">
                                    <span class="carousel-control-next-icon"></span>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center rounded mb-3"
                             style="height:200px;">
                            <span class="text-muted" data-i18n="detalle.sinImagenes">Sin imágenes disponibles</span>
                        </div>
                    }

                    <!-- Datos del ganado -->
                    <table class="table table-borderless table-sm mb-0">
                        <tbody>
                            <tr>
                                <th class="text-muted" style="width:45%" data-i18n="detalle.nombre">Nombre</th>
                                <td class="fw-semibold">@Model.NombreGanado</td>
                            </tr>
                            <tr>
                                <th class="text-muted" data-i18n="detalle.tipo">Tipo</th>
                                <td>@Model.TipoGanado</td>
                            </tr>
                            <tr>
                                <th class="text-muted" data-i18n="detalle.condicion">Condición</th>
                                <td>
                                    @if (!string.IsNullOrEmpty(Model.CertificadoSalud))
                                    {
                                        <span class="badge bg-success"><i class="bi bi-patch-check me-1"></i><span
                                            data-i18n="detalle.certificadoApto">Certificado y apto</span></span>
                                            <br />

                                            <small class="text-muted">@Model.CertificadoSalud</small>
                                        }
                                else
                                        {
                                            <span class="badge bg-warning text-dark"><i
                                                class="bi bi-exclamation-triangle me-1"></i><span
                                                data-i18n="detalle.sinCertificacion">Sin certificación</span></span>
                                            }
                                        </td>
                                    </tr>
                                    <tr>
                                        <th class="text-muted" data-i18n="detalle.categorias">Categorías</th>
                                        <td>
                                            @if (Model.Categorias.Any())
                                            {
                                                @foreach (var cat in Model.Categorias)
                                                {
                                                    <span class="badge bg-info text-dark me-1">@cat</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted" data-i18n="detalle.sinCategorias">Sin categorías</span>
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- ══ Columna Derecha: Subasta ══════════════════════════════════════════ -->
                <div class="col-md-7">
                    <div class="card shadow-sm h-100">
                        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                            <span class="fw-bold"><i class="bi bi-clipboard me-1"></i> <span data-i18n="detalle.infoSubasta">Datos
                                de la Subasta</span> #@Model.SubastaId</span>
                                <span class="badge @badgeEstado fs-6">@Model.EstadoSubasta</span>
                            </div>
                            <div class="card-body">

                                <div class="row g-3">
                                    <!-- Fechas -->
                                    <div class="col-sm-6">
                                        <label class="form-label text-muted small mb-0" data-i18n="detalle.fechaInicio">Fecha de
                                            Inicio</label>
                                            <div class="fw-semibold">@Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</div>
                                        </div>
                                        <div class="col-sm-6">
                                            <label class="form-label text-muted small mb-0" data-i18n="detalle.fechaCierre">Fecha de
                                                Cierre</label>
                                                <div class="fw-semibold">@Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</div>
                                            </div>

                                            <!-- Precios -->
                                            <div class="col-sm-6">
                                                <label class="form-label text-muted small mb-0" data-i18n="detalle.precioBase">Precio
                                                    Base</label>
                                                    <div class="fw-semibold text-success fs-5">₡@Model.PrecioBase.ToString("N2")</div>
                                                </div>
                                                <div class="col-sm-6">
                                                    <label class="form-label text-muted small mb-0" data-i18n="detalle.incrementoMinimo">Incremento
                                                        Mínimo</label>
                                                        <div class="fw-semibold">₡@Model.IncrementoMinimo.ToString("N2")</div>
                                                    </div>

                                                    <!-- Campo calculado: total de pujas -->
                                                    <div class="col-12">
                                                        <hr class="my-1" />
                                                        <label class="form-label text-muted small mb-0" data-i18n="detalle.totalPujas">Total de Pujas
                                                            Registradas</label>
                                                            <div>
                                                                <span class="badge bg-primary fs-5 py-2 px-3">@Model.TotalPujas puja(s)</span>
                                                            </div>
                                                        </div>

                                                        <!-- Creador -->
                                                        <div class="col-12">
                                                            <label class="form-label text-muted small mb-0" data-i18n="detalle.creadoPor">Creado por</label>
                                                            <div>@Model.NombreCreador</div>
                                                        </div>
                                                    </div>

                                                </div>
                                                <div class="card-footer">
                                                    <!-- Enlace obligatorio al historial de pujas -->
                                                    <a asp-action="HistorialPujas" asp-route-id="@Model.SubastaId" class="btn btn-primary w-100">
                                                        <i class="bi bi-list-ul me-1"></i>
                                                        <span data-i18n="detalle.verHistorial">Ver Historial de Pujas</span>
                                                        (@Model.TotalPujas)
                                                    </a>
                                                </div>
                                            </div>
                                        </div>

                                    </div>

                                    <div class="mt-3">
                                        <div class="d-grid gap-2 d-md-block">
                                            <div class="d-flex flex-wrap gap-2">
                                                <a asp-action="Activas" class="btn btn-outline-secondary">
                                                    <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.subastas">Subastas Activas</span>
                                                </a>
                                                <a asp-action="Finalizadas" class="btn btn-outline-secondary">
                                                    <i class="bi bi-arrow-left me-1"></i> <span data-i18n="detalle.finalizadas">Subastas Finalizadas</span>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@Model.SubastaId" asp-route-from="activas"
                                                       class="btn btn-outline-warning">
                                                    <i class="bi bi-pencil me-1"></i> <span data-i18n="detalle.editarBtn">Editar</span>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@Model.SubastaId" asp-route-from="activas"
                                                       class="btn btn-outline-danger">
                                                    <i class="bi bi-trash me-1"></i> <span data-i18n="detalle.eliminarBtn">Eliminar</span>
                                                </a>
                                            </div>
                                        </div>
                                    </div>