@model SuVac.Application.DTOs.SubastaDTO
@using System.Globalization
@{
    ViewData["Title"] = "Nueva Subasta";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Subastas</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Nueva Subasta</li>
    </ol>
</nav>

<header class="mb-3">
    <h1 class="h3 mb-0">Nueva Subasta</h1>
    <p class="text-muted mb-0">Mantenimiento: registro de una nueva subasta (se guardará como borrador)</p>
</header>

<form asp-action="Create" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="col-12 text-danger"></div>

    <!-- Ocultos -->
    <input asp-for="UsuarioCreadorId" type="hidden" />

    <!-- Sección: Ganado Subastable -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2">
            <i class="bi bi-cow me-1"></i> Ganado Subastable
        </h5>
    </div>

    <div class="col-12">
        <label asp-for="GanadoId" class="form-label"></label>
        <select asp-for="GanadoId" class="form-select" asp-items="ViewBag.ListGanado">
            <option value="">-- Seleccione un ganado --</option>
        </select>
        <div class="form-text">Solo se muestran ganados activos sin subasta vigente.</div>
        <span asp-validation-for="GanadoId" class="text-danger"></span>
    </div>

    <!-- Sección: Vendedor -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2 mt-2">
            <i class="bi bi-person me-1"></i> Vendedor
        </h5>
    </div>

    <div class="col-md-6">
        <label class="form-label">Vendedor / Creador</label>
        <input type="text" class="form-control" value="@ViewBag.NombreUsuarioActual" disabled />
        <div class="form-text">Asignado automáticamente al usuario en sesión.</div>
    </div>

    <!-- Sección: Fechas -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2 mt-2">
            <i class="bi bi-calendar-range me-1"></i> Fechas de la Subasta
        </h5>
    </div>

    <div class="col-md-6">
        <label asp-for="FechaInicio" class="form-label"></label>
        <input asp-for="FechaInicio" class="form-control" type="datetime-local"
               value="@Model.FechaInicio.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="FechaInicio" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="FechaFin" class="form-label"></label>
        <input asp-for="FechaFin" class="form-control" type="datetime-local"
               value="@Model.FechaFin.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="FechaFin" class="text-danger"></span>
    </div>

    <!-- Sección: Condiciones económicas -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2 mt-2">
            <i class="bi bi-currency-dollar me-1"></i> Condiciones Económicas
        </h5>
    </div>

    <div class="col-md-6">
        <label asp-for="PrecioBase" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">₡</span>
            <input asp-for="PrecioBase" class="form-control" type="number" min="0.01" step="0.01" inputmode="decimal"
                   placeholder="Ej: 125000.00"
                   value="@(Model.PrecioBase > 0 ? Model.PrecioBase.ToString("0.00", CultureInfo.InvariantCulture) : string.Empty)" />
        </div>
        <div class="form-text">Ingrese un monto positivo. Ejemplo: 125000.00</div>
        <span asp-validation-for="PrecioBase" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="IncrementoMinimo" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">₡</span>
            <input asp-for="IncrementoMinimo" class="form-control" type="number" min="0.01" step="0.01"
                   inputmode="decimal" placeholder="Ej: 5000.00"
                   value="@(Model.IncrementoMinimo > 0 ? Model.IncrementoMinimo.ToString("0.00", CultureInfo.InvariantCulture) : string.Empty)" />
        </div>
        <div class="form-text">Ingrese el incremento mínimo esperado. Ejemplo: 5000.00</div>
        <span asp-validation-for="IncrementoMinimo" class="text-danger"></span>
    </div>

    <!-- Botones -->
    <div class="col-12 d-flex gap-2 flex-wrap align-items-stretch">
        <button type="submit" name="accion" value="" class="btn btn-primary action-btn-fixed">
            <i class="bi bi-check2-circle me-1"></i> Guardar como borrador
        </button>
        <button type="submit" name="accion" value="publicar" class="btn btn-success action-btn-fixed">
            <i class="bi bi-send me-1"></i> Publicar directamente
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary action-btn-fixed">
            Volver
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
                    .action-btn-fixed {
                        min-width: 13rem;
                        min-height: 2.75rem;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                    }
    </style>
}