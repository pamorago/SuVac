@model SuVac.Application.DTOs.SubastaDTO

@{
    ViewData["Title"] = "Eliminar Subasta";
    var from = ViewBag.From as string ?? "activas";
    var volverAction = from == "finalizadas" ? "Finalizadas" : "Activas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0" data-i18n="subasta.eliminarTitle">Eliminar Subasta</h1>
    <a asp-action="@volverAction" class="btn btn-secondary" data-i18n="comun.volver">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <div data-i18n="subasta.confirmarEliminar">¿Estás seguro de que querés eliminar esta subasta? Esta acción no se
        puede deshacer.</div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.SubastaId</dd>

                <dt class="col-sm-3" data-i18n="subasta.ganadoId">Ganado (ID)</dt>
                <dd class="col-sm-9">@Model.GanadoId</dd>

                <dt class="col-sm-3" data-i18n="subasta.precioBase">Precio Base</dt>
                <dd class="col-sm-9">$@Model.PrecioBase.ToString("F2")</dd>

                <dt class="col-sm-3" data-i18n="detalle.incrementoMinimo">Incremento Mínimo</dt>
                <dd class="col-sm-9">$@Model.IncrementoMinimo.ToString("F2")</dd>

                <dt class="col-sm-3" data-i18n="subasta.estadoId">Estado (ID)</dt>
                <dd class="col-sm-9">@Model.EstadoSubastaId</dd>

                <dt class="col-sm-3" data-i18n="detalle.fechaInicio">Fecha Inicio</dt>
                <dd class="col-sm-9">@Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3" data-i18n="subasta.fechaFin">Fecha Fin</dt>
                <dd class="col-sm-9">@Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>
    </div>

    <form asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="SubastaId" />
        <input type="hidden" name="from" value="@from" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger" data-i18n="subasta.siEliminar">
                <i class="bi bi-trash me-1"></i>Sí, eliminar
            </button>
            <a asp-action="@volverAction" class="btn btn-secondary" data-i18n="comun.cancelar">Cancelar</a>
        </div>
    </form>