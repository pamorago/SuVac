@model SuVac.Application.DTOs.SubastaDetalleDTO
@{
    ViewData["Title"] = $"Detalle de Subasta #{Model.SubastaId}";
    var badgeClase = Model.EstadoSubasta switch
    {
        "Activa" => "text-bg-success",
        "Finalizada" => "text-bg-dark",
        "Cancelada" => "text-bg-danger",
        "Programada" => "text-bg-primary",
        "Borrador" => "text-bg-secondary",
        _ => "text-bg-info"
    };
    var puedeEditar = Model.EstadoSubasta != "Finalizada" && Model.EstadoSubasta != "Cancelada" && Model.TotalPujas == 0;
    var puedePublicar = Model.EstadoSubasta == "Borrador";
    var puedeCancelar = Model.EstadoSubasta != "Cancelada"
                         && Model.EstadoSubasta != "Finalizada"
                         && Model.TotalPujas == 0;
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Subastas</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Detalle #@Model.SubastaId</li>
    </ol>
</nav>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Detalle de Subasta <span class="badge @badgeClase">@Model.EstadoSubasta</span></h1>
        <p class="text-muted mb-0">Subasta #@Model.SubastaId &mdash; @Model.NombreGanado</p>
    </div>
    <div class="d-flex gap-2">
        @{
            var volverAction = ViewBag.From == "activas" ? "Activas"
                             : ViewBag.From == "finalizadas" ? "Finalizadas"
                             : "Index";
            var volverTexto = ViewBag.From == "activas" ? "Volver a Activas"
                            : ViewBag.From == "finalizadas" ? "Volver a Finalizadas"
                            : "Volver al listado";
        }
        <a asp-action="@volverAction" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> @volverTexto
        </a>
    </div>
</div>

<div class="card shadow-sm border-0 overflow-hidden mb-3">
    <div class="row g-0">

        <!-- Columna izquierda: Ganado -->
        <div class="col-12 col-lg-5 bg-body-tertiary">

            @if (Model.ImagenesGanado.Any())
            {
                <div id="carrusel-ganado" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.ImagenesGanado.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@Model.ImagenesGanado[i]" class="d-block w-100"
                                     alt="Imagen @(i + 1) de @Model.NombreGanado" style="height: 300px; object-fit: cover;"
                                     onerror="this.src='/img/sin-imagen.png'" />
                            </div>
                        }
                    </div>
                    @if (Model.ImagenesGanado.Count > 1)
                    {
                        <button class="carousel-control-prev" type="button" data-bs-target="#carrusel-ganado"
                                data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carrusel-ganado"
                                data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                        </button>
                    }
                </div>
            }
            else
            {
                <div class="ratio ratio-4x3 d-flex flex-column justify-content-center align-items-center text-muted"
                     style="min-height: 200px;">
                    <i class="bi bi-image fs-1"></i>
                    <span class="small">Sin imágenes disponibles</span>
                </div>
            }

            <div class="p-3">
                <h5 class="fw-semibold mb-3">
                    <i class="bi bi-cow me-1"></i> Ganado Subastable
                </h5>
                <dl class="row mb-0">
                    <dt class="col-5 text-muted">Nombre</dt>
                    <dd class="col-7 fw-semibold">@Model.NombreGanado</dd>

                    <dt class="col-5 text-muted">Tipo</dt>
                    <dd class="col-7">@Model.TipoGanado</dd>

                    <dt class="col-5 text-muted">Estado</dt>
                    <dd class="col-7">
                        <span class="badge text-bg-light border">@Model.EstadoGanado</span>
                    </dd>

                    <dt class="col-5 text-muted">Condición</dt>
                    <dd class="col-7">
                        @if (!string.IsNullOrEmpty(Model.CertificadoSalud))
                        {
                            <span class="badge text-bg-success">
                                <i class="bi bi-patch-check me-1"></i> Certificado y apto
                            </span>
                            <div class="small text-muted mt-1">@Model.CertificadoSalud</div>
                        }
                        else
                        {
                            <span class="badge text-bg-warning">
                                <i class="bi bi-exclamation-triangle me-1"></i> Sin certificación
                            </span>
                        }
                    </dd>

                    <dt class="col-5 text-muted">Categorías</dt>
                    <dd class="col-7">
                        @if (Model.Categorias.Any())
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var cat in Model.Categorias)
                                {
                                    <span class="badge text-bg-light border">
                                        <i class="bi bi-tag me-1"></i>@cat
                                    </span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="text-muted">Sin categorías</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>

        <!-- Columna derecha: Subasta -->
        <div class="col-12 col-lg-7">
            <div class="card-body p-4">

                <header class="mb-3">
                    <h2 class="h5 fw-semibold mb-1">
                        <i class="bi bi-clipboard-check me-1"></i> Condiciones de la Subasta
                    </h2>
                    <div class="d-flex gap-2 align-items-center flex-wrap">
                        <span class="badge @badgeClase fs-6">@Model.EstadoSubasta</span>
                        <span class="text-muted small">Subasta #@Model.SubastaId</span>
                    </div>
                </header>

                <hr class="my-3" />

                <dl class="row mb-0">
                    <dt class="col-12 col-md-5 text-muted">Fecha de Inicio</dt>
                    <dd class="col-12 col-md-7 fw-semibold">@Model.FechaInicio.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-12 col-md-5 text-muted">Fecha de Cierre</dt>
                    <dd class="col-12 col-md-7 fw-semibold">@Model.FechaFin.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-12 col-md-5 text-muted">Precio Base</dt>
                    <dd class="col-12 col-md-7">
                        <span class="fw-semibold text-success fs-5">₡@Model.PrecioBase.ToString("N2")</span>
                    </dd>

                    <dt class="col-12 col-md-5 text-muted">Incremento Mínimo</dt>
                    <dd class="col-12 col-md-7 fw-semibold">₡@Model.IncrementoMinimo.ToString("N2")</dd>

                    <dt class="col-12 col-md-5 text-muted">Total de Pujas</dt>
                    <dd class="col-12 col-md-7">
                        <span class="badge text-bg-primary fs-6 py-1 px-3">@Model.TotalPujas puja(s)</span>
                    </dd>

                    <dt class="col-12 col-md-5 text-muted">Vendedor / Creador</dt>
                    <dd class="col-12 col-md-7">@Model.NombreCreador</dd>
                </dl>

                <hr class="my-4" />

                @if (Model.EstadoSubasta == "Finalizada" && Model.NombreGanador != null)
                {
                    <div class="alert alert-success border-success d-flex align-items-center gap-3 mb-4" role="alert">
                        <i class="bi bi-trophy-fill fs-3 text-warning"></i>
                        <div>
                            <div class="fw-bold fs-6 mb-1">Ganador de la Subasta</div>
                            <div class="fs-5 fw-semibold">@Model.NombreGanador</div>
                            <div class="text-muted">Monto final: <span
                                class="fw-bold text-success">₡@Model.MontoFinal?.ToString("N2")</span></div>
                            </div>
                        </div>
                    }

                    <!-- Acciones -->
                    <div class="d-flex flex-column flex-sm-row flex-wrap gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i> Volver al listado
                        </a>

                        @if (puedeEditar)
                        {
                            <a asp-action="Edit" asp-route-id="@Model.SubastaId" class="btn btn-outline-warning">
                                <i class="bi bi-pencil me-1"></i> Editar
                            </a>
                        }

                        @if (puedePublicar)
                        {
                            <form asp-action="Publicar" asp-route-id="@Model.SubastaId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-send me-1"></i> Publicar
                                </button>
                            </form>
                        }

                        @if (puedeCancelar)
                        {
                            <a asp-action="Cancelar" asp-route-id="@Model.SubastaId" class="btn btn-outline-danger">
                                <i class="bi bi-x-circle me-1"></i> Cancelar subasta
                            </a>
                        }

                        <a asp-action="HistorialPujas" asp-route-id="@Model.SubastaId" class="btn btn-primary">
                            <i class="bi bi-list-ul me-1"></i> Ver historial de pujas (@Model.TotalPujas)
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>