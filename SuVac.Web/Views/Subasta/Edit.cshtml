@model SuVac.Application.DTOs.SubastaDTO
@using System.Globalization
@{
    ViewData["Title"] = $"Editar Subasta #{Model.SubastaId}";
}

<nav class="mb-3">
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Inicio</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Subastas</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">Editar #@Model.SubastaId</li>
    </ol>
</nav>

<header class="mb-3">
    <h1 class="h3 mb-0">Editar Subasta <small class="text-muted fs-5">#@Model.SubastaId</small></h1>
    <p class="text-muted mb-0">Mantenimiento: actualización de la subasta</p>
</header>

<div class="alert alert-warning" role="alert">
    <div>
        <strong>Restricciones de edición:</strong> Solo puede modificar fechas y precios.
        La subasta no puede haber iniciado o tener pujas registradas.
        El ganado y el vendedor no pueden cambiarse.
    </div>
</div>

<form asp-action="Edit" asp-route-id="@Model.SubastaId" method="post" class="row g-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="col-12 text-danger"></div>

    <!-- Campos ocultos necesarios para el POST -->
    <input asp-for="SubastaId" type="hidden" />
    <input asp-for="GanadoId" type="hidden" />
    <input asp-for="UsuarioCreadorId" type="hidden" />
    <input asp-for="EstadoSubastaId" type="hidden" />

    <!-- Sección: Datos no editables -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2">
            <i class="bi bi-lock me-1"></i> Datos fijos (no editables)
        </h5>
    </div>

    <div class="col-md-6">
        <label class="form-label">Ganado</label>
        <input type="text" class="form-control" value="@Model.NombreGanado" disabled />
    </div>

    <div class="col-md-6">
        <label class="form-label">Estado</label>
        <input type="text" class="form-control" value="@Model.NombreEstadoSubasta" disabled />
    </div>

    <div class="col-md-6">
        <label class="form-label">Vendedor / Creador</label>
        <input type="text" class="form-control" value="@Model.NombreCreador" disabled />
    </div>

    <!-- Sección: Fechas -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2 mt-2">
            <i class="bi bi-calendar-range me-1"></i> Fechas de la Subasta
        </h5>
    </div>

    <div class="col-md-6">
        <label asp-for="FechaInicio" class="form-label"></label>
        <input asp-for="FechaInicio" class="form-control" type="datetime-local"
               value="@Model.FechaInicio.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="FechaInicio" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="FechaFin" class="form-label"></label>
        <input asp-for="FechaFin" class="form-control" type="datetime-local"
               value="@Model.FechaFin.ToString("yyyy-MM-ddTHH:mm")" />
        <span asp-validation-for="FechaFin" class="text-danger"></span>
    </div>

    <!-- Sección: Condiciones económicas -->
    <div class="col-12">
        <h5 class="fw-semibold border-bottom pb-2 mb-2 mt-2">
            <i class="bi bi-currency-dollar me-1"></i> Condiciones Económicas
        </h5>
    </div>

    <div class="col-md-6">
        <label asp-for="PrecioBase" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">₡</span>
            <input asp-for="PrecioBase" class="form-control" type="number" min="0.01" step="0.01" inputmode="decimal"
                   placeholder="Ej: 125000.00" value="@Model.PrecioBase.ToString("0.00", CultureInfo.InvariantCulture)" />
        </div>
        <div class="form-text">Ejemplo de formato: 125000.00</div>
        <span asp-validation-for="PrecioBase" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="IncrementoMinimo" class="form-label"></label>
        <div class="input-group">
            <span class="input-group-text">₡</span>
            <input asp-for="IncrementoMinimo" class="form-control" type="number" min="0.01" step="0.01"
                   inputmode="decimal" placeholder="Ej: 5000.00"
                   value="@Model.IncrementoMinimo.ToString("0.00", CultureInfo.InvariantCulture)" />
        </div>
        <div class="form-text">Ejemplo de formato: 5000.00</div>
        <span asp-validation-for="IncrementoMinimo" class="text-danger"></span>
    </div>

    <!-- Botones -->
    <div class="col-12 d-flex gap-2 flex-wrap align-items-stretch">
        <button type="submit" class="btn btn-warning action-btn-fixed">
            <i class="bi bi-save2 me-1"></i> Guardar cambios
        </button>
        <a asp-action="Detalle" asp-route-id="@Model.SubastaId" class="btn btn-outline-secondary action-btn-fixed">
            Volver al detalle
        </a>
        <a href="javascript:history.go(-2)" class="btn btn-outline-secondary action-btn-fixed">
            Volver al listado
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <style>
                    .action-btn-fixed {
                        min-width: 13rem;
                        min-height: 2.75rem;
                        display: inline-flex;
                        align-items: center;
                        justify-content: center;
                    }
    </style>
}