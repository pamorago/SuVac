@model SuVac.Web.ViewModels.ViewModelLogin
@{
    Layout = null;
    ViewData["Title"] = "Iniciar sesión";
}
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SuVac</title>
    <link rel="icon" type="image/png" href="~/img/Icono%20Subasta.png" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5/dist/brite/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/sweetalert2/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="bg-body">
    <div class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
        <div class="row justify-content-center w-100">
            <div class="col-12 col-sm-10 col-md-7 col-lg-5 col-xl-4">

                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-primary text-white text-center py-4 border-0">
                        <i class="bi bi-cow display-5 mb-2 d-block"></i>
                        <h2 class="h4 mb-1 fw-bold">SuVac</h2>
                        <p class="small mb-0 opacity-75">Sistema de Subastas de Ganado</p>
                    </div>

                    <div class="card-body p-4 p-md-5 text-dark">

                        @if (TempData["LoginError"] != null)
                        {
                            <div class="alert alert-danger d-flex align-items-center gap-2" role="alert">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <span>@TempData["LoginError"]</span>
                            </div>
                        }

                        <form asp-controller="Login" asp-action="LogIn" method="post">
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="User" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
                                    <input asp-for="User" class="form-control" type="email"
                                           placeholder="correo@ejemplo.com" autocomplete="username" />
                                </div>
                                <span asp-validation-for="User" class="text-danger small"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Password" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                                    <input asp-for="Password" id="inputPassword" class="form-control" type="password"
                                           placeholder="Contraseña" autocomplete="current-password" />
                                    <button class="btn btn-outline-secondary" type="button" id="togglePassword"
                                            title="Mostrar u ocultar contraseña">
                                        <i class="bi bi-eye" id="eyeIcon"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="Password" class="text-danger small"></span>
                            </div>

                            <div class="d-grid mt-4">
                                <button class="btn btn-primary btn-lg" type="submit" id="btnLogin">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar sesión
                                </button>
                            </div>
                        </form>

                        <hr class="my-4" />

                        <p class="text-center small mb-0">
                            ¿No tenés cuenta?
                            <a asp-controller="Login" asp-action="Registro" class="fw-semibold">Registrate aquí</a>
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/sweetalert2/dist/sweetalert2.min.js"></script>

    @if (TempData["Notificacion"] != null)
    {
        <script>
            const n = @Html.Raw(TempData["Notificacion"]);
            Swal.fire({ title: n.title, text: n.text, icon: n.icon, timer: 3000, showConfirmButton: false });
        </script>
    }

    <script>
        document.getElementById('btnLogin').addEventListener('click', function () {
        this.disabled = true;
        this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Validando...';
        this.closest('form').submit();
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>

</html>
