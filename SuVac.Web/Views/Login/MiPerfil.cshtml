@model SuVac.Application.DTOs.UsuarioDTO

@{
    ViewData["Title"] = "Mi perfil";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-xl-8">

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 py-3">
                    <h4 class="mb-0"><i class="bi bi-person-circle me-2"></i>Mi perfil</h4>
                </div>
                <div class="card-body p-4">

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Nombre completo</label>
                            <p class="form-control-plaintext">@Model.NombreCompleto</p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Correo electrónico</label>
                            <p class="form-control-plaintext">@Model.Correo</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Rol</label>
                            <p class="form-control-plaintext">
                                @{
                                    var badgeRol = Model.NombreRol switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Vendedor" => "bg-warning text-dark",
                                        _ => "bg-info text-dark"
                                    };
                                }
                                <span class="badge @badgeRol">@Model.NombreRol</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Estado</label>
                            <p class="form-control-plaintext">
                                @if (Model.NombreEstado == "Activo")
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Model.NombreEstado</span>
                                }
                            </p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Fecha de registro</label>
                            <p class="form-control-plaintext">@Model.FechaRegistro.ToString("dd/MM/yyyy")</p>
                        </div>
                    </div>

                    <hr />

                    <div class="row g-3 text-center">
                        <div class="col-md-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <h3 class="mb-0 text-primary">@Model.CantidadSubastasCreadas</h3>
                                    <p class="text-muted small mb-0">Subastas creadas</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card bg-light border-0">
                                <div class="card-body py-3">
                                    <h3 class="mb-0 text-primary">@Model.CantidadPujasRealizadas</h3>
                                    <p class="text-muted small mb-0">Pujas realizadas</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div class="card-footer bg-transparent d-flex gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-house me-1"></i>Inicio
                    </a>
                    <a asp-controller="Login" asp-action="Historial" class="btn btn-outline-primary">
                        <i class="bi bi-clock-history me-1"></i>Mi historial
                    </a>
                    <a asp-controller="Login" asp-action="LogOff" class="btn btn-outline-danger ms-auto">
                        <i class="bi bi-box-arrow-left me-1"></i>Cerrar sesión
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
