@model IEnumerable<SuVac.Application.DTOs.HistorialUsuarioDTO>

@{
    ViewData["Title"] = "Mi historial";
    var lista = Model.ToList();
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-12 col-xl-10">

            <div class="d-flex align-items-center justify-content-between mb-4">
                <h3 class="mb-0">
                    <i class="bi bi-clock-history me-2 text-primary"></i>Mi historial de subastas
                </h3>
                <a asp-controller="Login" asp-action="MiPerfil" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-person me-1"></i>Mi perfil
                </a>
            </div>

            @if (!lista.Any())
            {
                <div class="alert alert-info d-flex align-items-center gap-2">
                    <i class="bi bi-info-circle-fill fs-5"></i>
                    <span>Todavía no participaste en ninguna subasta.</span>
                </div>
            }
            else
            {
                <!-- Resumen rápido -->
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="card border-0 bg-primary text-white text-center">
                            <div class="card-body py-3">
                                <h3 class="mb-0">@lista.Count</h3>
                                <p class="small mb-0">Subastas totales</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 bg-success text-white text-center">
                            <div class="card-body py-3">
                                <h3 class="mb-0">@lista.Count(x => x.RolEnSubasta == "Vendedor")</h3>
                                <p class="small mb-0">Como vendedor</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 bg-info text-white text-center">
                            <div class="card-body py-3">
                                <h3 class="mb-0">@lista.Count(x => x.RolEnSubasta == "Comprador")</h3>
                                <p class="small mb-0">Como comprador</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Ganado</th>
                                <th>Fecha inicio</th>
                                <th>Fecha fin</th>
                                <th>Estado</th>
                                <th>Mi rol</th>
                                <th>Precio base</th>
                                <th>Mi mejor puja</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in lista)
                            {
                                <tr>
                                    <td>@item.SubastaId</td>
                                    <td class="fw-semibold">@item.NombreGanado</td>
                                    <td>@item.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var badgeEstado = item.EstadoSubasta switch
                                            {
                                                "Activa" => "bg-success",
                                                "Finalizada" => "bg-secondary",
                                                "Cancelada" => "bg-danger",
                                                _ => "bg-warning text-dark"
                                            };
                                        }
                                        <span class="badge @badgeEstado">@item.EstadoSubasta</span>
                                    </td>
                                    <td>
                                        @if (item.RolEnSubasta == "Comprador")
                                        {
                                            if (item.EsGanador)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-trophy-fill me-1"></i>Ganador
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info text-dark">Comprador</span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Vendedor</span>
                                        }
                                    </td>
                                    <td>$@item.PrecioBase.ToString("N2")</td>
                                    <td>
                                        @if (item.MejorPuja.HasValue)
                                        {
                                            <span class="text-primary fw-semibold">$@item.MejorPuja.Value.ToString("N2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                    <td>
                                        <a asp-controller="Subasta" asp-action="Detalle" asp-route-id="@item.SubastaId"
                                               class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>Ver
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }

        </div>
    </div>
</div>
