@model SuVac.Application.DTOs.PujaDTO

@{
    ViewData["Title"] = "Eliminar Puja";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1" data-i18n="puja.deleteTitle">Eliminar Puja</h1>
        <p class="text-muted mb-0" data-i18n="puja.deleteSubtitulo">Confirmar la eliminación de la puja seleccionada.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" data-i18n="comun.volver">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>
    <div data-i18n="puja.confirmarEliminar">¿Estás seguro de que querés eliminar esta puja? Esta acción no se puede
        deshacer.</div>
    </div>

    <article class="card shadow-sm border-0 mb-3">
        <div class="card-body p-4">
            <dl class="row mb-0">
                <dt class="col-12 col-md-3 text-muted">Puja #</dt>
                <dd class="col-12 col-md-9">@Model.PujaId</dd>

                <dt class="col-12 col-md-3 text-muted" data-i18n="puja.colUsuario">Usuario</dt>
                <dd class="col-12 col-md-9 fw-semibold">@Model.NombreUsuario</dd>

                <dt class="col-12 col-md-3 text-muted" data-i18n="puja.colSubasta">Subasta</dt>
                <dd class="col-12 col-md-9">Subasta #@Model.SubastaId</dd>

                <dt class="col-12 col-md-3 text-muted" data-i18n="puja.colMonto">Monto</dt>
                <dd class="col-12 col-md-9">@Model.Monto.ToString("N2")</dd>

                <dt class="col-12 col-md-3 text-muted" data-i18n="puja.colFecha">Fecha y hora</dt>
                <dd class="col-12 col-md-9">@Model.FechaHora.ToString("dd/MM/yyyy HH:mm")</dd>
            </dl>
        </div>
    </article>

    <form asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="PujaId" />
        <div class="d-flex flex-column flex-sm-row gap-2 justify-content-end">
            <a asp-action="Index" class="btn btn-outline-secondary" data-i18n="comun.cancelar">Cancelar</a>
            <button type="submit" class="btn btn-danger" data-i18n="puja.siEliminar">
                <i class="bi bi-trash me-1"></i> Sí, eliminar
            </button>
        </div>
    </form>